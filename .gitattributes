# Normalize text file line endings to LF on commit, regardless of platform.
# Prevents CRLF <-> LF drift when files are touched from Windows vs. WSL.

* text=auto eol=lf

# Text types (explicit so no heuristic misfires)
*.tex  text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.sh   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg  text eol=lf
*.ini  text eol=lf

# Binary types (never munge)
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.gz  binary
*.tar binary
