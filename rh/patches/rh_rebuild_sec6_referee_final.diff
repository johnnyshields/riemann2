+\begin{lemma}[Two-point scalar quotient well-definedness]
+\label{lem:A2-quotient-well-defined}
+The scalar channel \(\mathcal A_2\) descends to the quotient
+\(M_2(\mathbb R)/\mathcal V_\val\).  Equivalently, if
+\(X-Y\in\mathcal V_\val\), then
+\begin{equation}
+\label{eq:A2-quotient-well-defined}
+        \mathcal A_2(X)=\mathcal A_2(Y).
+\end{equation}
+Moreover, for every \(X\in M_2(\mathbb R)\),
+\begin{equation}
+\label{eq:A2-representative-identities}
+        \mathcal A_2(X)
+        =\mathcal A_\toy(\Pi_\trans X)
+        =\mathcal A_\toy(X)
+        =\sqrt2\,\langle X,e_\sym\rangle_{\mathrm{HS}}.
+\end{equation}
+\end{lemma}
+
+\begin{proof}
+If \(X-Y\in\mathcal V_\val=\ker\mathcal A_\toy\), then
+\(\mathcal A_\toy(X)-\mathcal A_\toy(Y)=0\).  By
+Definition~\ref{def:two-point-scalar-transverse-channel} and
+Lemma~\ref{lem:transverse-projection-A-toy-compatibility},
+\(\mathcal A_2=\mathcal A_\toy\) on matrix representatives; hence
+\eqref{eq:A2-quotient-well-defined}.  The identities in
+\eqref{eq:A2-representative-identities} follow from
+Lemma~\ref{lem:transverse-projection-A-toy-compatibility} and
+\(\langle X,e_\sym\rangle_{\mathrm{HS}}=(x_{12}+x_{21})/\sqrt2\).
+\end{proof}
