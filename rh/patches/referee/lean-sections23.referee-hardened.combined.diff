+  have h_T_sq_pos : 0 < T^2 := by positivity
+  have h_one_48 : 1 / (48 * t^2) ≤ 1 / (12 * T^2) := by
+    rw [div_le_div_iff₀ (by positivity) (by positivity)]
+    nlinarith
