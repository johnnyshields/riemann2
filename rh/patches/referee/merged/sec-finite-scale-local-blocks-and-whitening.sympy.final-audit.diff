+# ---------------------------------------------------------------------------
+# (iii) Signed-s orientation convention: N_m(-s) = N_m(s)^T.
+# ---------------------------------------------------------------------------
+
+def verify_signed_s_symmetry():
+    """Verify the signed-s convention used in def:finite-packet-domain.
+
+    Under s -> -s, the two centers t_- and t_+ are swapped and
+    Delta_m(-s)=-Delta_m(s).  Since K_Phi is symmetric, the mixed
+    derivative block should transpose:
+
+        N_m(-s) = N_m(s)^T.
+    """
+    print("=" * 70)
+    print("[signed-s convention]  N_m(-s) = N_m(s)^T")
+    print("=" * 70)
+    s, D = symbols("s Delta", real=True)
+    qmin, qplus = symbols("q_minus q_plus", real=True)
+
+    def Nm_unscaled(s_, D_, qm_, qp_):
+        return Matrix([
+            [
+                -2 * sin(D_) / s_,
+                (sin(D_) + qp_ * s_ * cos(D_)) / s_**2,
+            ],
+            [
+                -(sin(D_) + qm_ * s_ * cos(D_)) / s_**2,
+                ((qm_ + qp_) * s_ * cos(D_)
+                 + (2 - qm_ * qp_ * s_**2) * sin(D_)) / (2 * s_**3),
+            ],
+        ])
+
+    N_pos = Nm_unscaled(s, D, qmin, qplus)
+    # Reversing s swaps q_- and q_+, and sends Delta to -Delta.
+    N_neg = Nm_unscaled(-s, -D, qplus, qmin)
+    diff_sym = (N_neg - N_pos.T).applyfunc(lambda e: trigsimp(simplify(e)))
+    print()
+    print("  Difference N_m(-s) - N_m(s)^T:")
+    sp.pprint(diff_sym)
+    assert diff_sym == zeros(2, 2), f"signed-s transpose identity failed: {diff_sym}"
+    print()
+    print("  [PASS] Signed-s orientation is compatible with transposition.")
+
